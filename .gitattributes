# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf

# PowerShell scripts should use CRLF on Windows
*.ps1 text eol=crlf

# Makefiles must use tabs and LF
Makefile text eol=lf

# Docker files
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf

# Source code
*.java text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.properties text eol=lf

# Documentation
*.md text eol=lf

# Windows specific
*.bat text eol=crlf
*.cmd text eol=crlf
