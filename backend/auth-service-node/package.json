{
  "name": "auth-service-node",
  "version": "1.0.0",
  "description": "Authentication service with Keycloak integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "setup": "npm run db:create && npm run prisma:generate && npm run prisma:migrate && npm run seed",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:create": "node create-db.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "eureka-js-client": "^4.5.0",
    "express": "^4.18.2",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "prisma": "^5.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
