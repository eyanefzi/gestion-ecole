# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Shell scripts
[*.sh]
end_of_line = lf
indent_style = space
indent_size = 4

# PowerShell scripts
[*.ps1]
end_of_line = crlf
indent_style = space
indent_size = 4

# Makefile
[Makefile]
indent_style = tab
end_of_line = lf

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Java files
[*.java]
indent_style = space
indent_size = 4

# TypeScript/JavaScript
[*.{ts,js}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Docker files
[Dockerfile]
end_of_line = lf

[docker-compose.yml]
indent_style = space
indent_size = 2
end_of_line = lf
